---
const { effects } = Astro.props;
---

<section class="py-10 md:py-16 bg-[#FAFAF7]">
  <div class="max-w-[1160px] mx-auto px-4 md:px-8">
    <div class="text-center mb-6 md:mb-12">
      <p class="section-eyebrow mb-3">期待できる効果</p>
      <h2 class="section-heading">採点業務の効率化で、教育の時間を取り戻す</h2>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-5">
      {effects.map((effect) => (
        <div class="card text-center rounded-lg">
          <p class="text-[1.75rem] md:text-4xl font-bold text-[#1F6B4D] mb-1.5 md:mb-2">{effect.value}</p>
          <p class="copy-pre-line font-semibold text-[#111827] text-xs md:text-sm leading-snug mb-1">{effect.label}</p>
          {effect.note && <p class="copy-pre-line text-[9px] md:text-[10px] text-[#9CA3AF]">{effect.note}</p>}
        </div>
      ))}
    </div>
    <div class="text-center mt-6 md:mt-10">
      <a href="#contact" class="btn-primary">採点業務の効率化について相談する</a>
    </div>
  </div>
</section>
