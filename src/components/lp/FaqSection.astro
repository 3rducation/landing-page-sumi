---
const { faqs } = Astro.props;
---

<section id="faq" class="py-20 md:py-28 bg-white">
  <div class="max-w-[1160px] mx-auto px-5 md:px-8">
    <div class="text-center mb-12">
      <p class="section-eyebrow mb-3">FAQ</p>
      <h2 class="section-heading">よくあるご質問</h2>
    </div>
    <div class="max-w-2xl mx-auto space-y-3">
      {faqs.map((faq) => (
        <details class="group border border-[#E5E7EB] rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-[#111827] text-sm hover:bg-[#F3FAF6] transition-colors list-none">
            <span>{faq.q}</span>
            <span class="text-[#1F6B4D] text-lg shrink-0 ml-3 transition-transform duration-200 group-open:rotate-45">+</span>
          </summary>
          <div class="px-6 pb-5 pt-3 text-sm text-[#4B5563] leading-relaxed border-t border-[#E5E7EB]">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
