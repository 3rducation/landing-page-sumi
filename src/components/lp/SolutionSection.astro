---
const { solution } = Astro.props;
---

<section class="py-20 md:py-28 bg-[#1F6B4D]">
  <div class="max-w-[1160px] mx-auto px-5 md:px-8">
    <div class="text-center mb-12">
      <p class="section-eyebrow section-eyebrow--on-dark copy-pre-line mb-3">{solution.eyebrow}</p>
      <h2 class="copy-pre-line text-2xl md:text-3xl lg:text-4xl font-bold text-white leading-tight">{solution.heading}</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-3xl mx-auto">
      {solution.points.map((point) => (
        <div class="flex items-start gap-3 bg-white/10 rounded-2xl p-5">
          <span class="text-[#A88B3D] text-xl mt-0.5 shrink-0">✓</span>
          <p class="copy-pre-line text-white font-medium leading-snug">{point}</p>
        </div>
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="#contact" class="inline-flex items-center gap-2 bg-white text-[#1F6B4D] font-semibold px-7 py-3 rounded-full hover:bg-[#EAF6F0] transition-colors">
        資料請求・デモ相談はこちら →
      </a>
    </div>
  </div>
</section>
