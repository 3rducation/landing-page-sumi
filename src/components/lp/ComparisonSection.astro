---
const { comparison } = Astro.props;
---

<section class="py-14 md:py-16 bg-white">
  <div class="max-w-[1160px] mx-auto px-4 md:px-8">
    <div class="text-center mb-8 md:mb-12">
      <p class="section-eyebrow copy-pre-line mb-3">{comparison.eyebrow}</p>
      <h2 class="section-heading copy-pre-line">{comparison.heading}</h2>
      <p class="copy-pre-line text-[#4B5563] mt-4 max-w-2xl mx-auto text-sm md:text-base leading-relaxed">
        {comparison.body}
      </p>
    </div>
    <div class="md:hidden space-y-3">
      {comparison.items.map((item) => (
        <div class="rounded-lg border border-[#E5E7EB] overflow-hidden">
          <div class="bg-[#FAFAF7] px-4 py-3">
            <h3 class="copy-pre-line font-semibold text-sm text-[#111827]">{item.label}</h3>
          </div>
          <div class="grid grid-cols-2">
            <div class="bg-[#F6F8F7] px-3 py-3">
              <p class="text-[10px] font-semibold text-[#4B5563] mb-1">従来のOCR採点</p>
              <p class="copy-pre-line text-[11px] leading-relaxed text-[#4B5563]">{item.ocr}</p>
            </div>
            <div class="bg-[#F3FAF6] px-3 py-3">
              <p class="text-[10px] font-semibold text-[#1F6B4D] mb-1">AI自動採点「澄」</p>
              <p class="copy-pre-line text-[11px] leading-relaxed text-[#1F6B4D] font-medium">{item.sumi}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="hidden md:block overflow-x-auto">
      <table class="w-full min-w-[540px] border-collapse">
        <thead>
          <tr class="text-sm">
            <th class="text-left py-3 px-4 text-[#9CA3AF] font-medium w-1/3"></th>
            <th class="py-3 px-4 text-center bg-[#F6F8F7] rounded-tl-lg text-[#4B5563] font-semibold">従来のOCR採点</th>
            <th class="py-3 px-4 text-center bg-[#EAF6F0] rounded-tr-lg text-[#1F6B4D] font-semibold">AI自動採点「澄」</th>
          </tr>
        </thead>
        <tbody>
          {comparison.items.map((item) => (
            <tr class="border-t border-[#E5E7EB] text-sm">
              <td class="copy-pre-line py-3.5 px-4 font-medium text-[#111827]">{item.label}</td>
              <td class="copy-pre-line py-3.5 px-4 text-center text-[#4B5563] bg-[#FAFAF7]">{item.ocr}</td>
              <td class="copy-pre-line py-3.5 px-4 text-center text-[#1F6B4D] bg-[#F3FAF6] font-medium">{item.sumi}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
