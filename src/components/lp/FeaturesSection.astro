---
const { features } = Astro.props;
---

<section id="features" class="py-10 md:py-28 bg-white">
  <div class="max-w-[1160px] mx-auto px-4 md:px-8">
    <div class="text-center mb-6 md:mb-12">
      <p class="section-eyebrow mb-3">特徴</p>
      <h2 class="section-heading">採点から返却まで、6つの機能で支援</h2>
    </div>
    <div class="grid grid-cols-2 gap-3 md:hidden">
      {features.map((feature, index) => (
        <button
          type="button"
          class="feature-mobile-card text-left bg-white border border-[#E5E7EB] rounded-3xl px-3.5 py-4 shadow-sm min-h-[138px]"
          data-feature-index={index}
        >
          <img src={feature.iconSrc} alt="" class="w-9 h-9 mb-2.5 block" />
          <h3 class="copy-pre-line font-semibold text-[#111827] text-base leading-snug">{feature.title}</h3>
        </button>
      ))}
    </div>
    <div class="hidden md:grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feature) => (
        <div class="card p-4 md:p-7 rounded-2xl">
          <img src={feature.iconSrc} alt="" class="w-10 h-10 md:w-12 md:h-12 mb-3 md:mb-4 block" />
          <h3 class="copy-pre-line font-semibold text-[#111827] mb-2 text-sm md:text-base leading-snug">{feature.title}</h3>
          <p class="copy-pre-line text-xs md:text-sm text-[#4B5563] leading-relaxed">{feature.body}</p>
        </div>
      ))}
    </div>
  </div>

  <div
    id="feature-mobile-overlay"
    class="fixed inset-0 z-[70] hidden bg-[#111827]/55 px-4 py-6 md:hidden"
    aria-hidden="true"
  >
    <div class="flex min-h-full items-center justify-center">
      <div class="w-full max-w-sm rounded-[28px] bg-white p-6 shadow-2xl">
        <div class="flex items-start justify-between gap-4">
          <div>
            <img id="feature-mobile-overlay-icon" alt="" class="w-10 h-10" />
            <h3 id="feature-mobile-overlay-title" class="mt-3 text-xl font-bold leading-snug text-[#111827]"></h3>
          </div>
          <button
            type="button"
            id="feature-mobile-overlay-close"
            class="shrink-0 rounded-full border border-[#E5E7EB] px-3 py-1 text-sm text-[#4B5563]"
            aria-label="閉じる"
          >
            閉じる
          </button>
        </div>
        <p id="feature-mobile-overlay-body" class="mt-5 text-sm leading-7 text-[#4B5563]"></p>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ features }}>
  const overlay = document.getElementById('feature-mobile-overlay');
  const overlayIcon = document.getElementById('feature-mobile-overlay-icon');
  const overlayTitle = document.getElementById('feature-mobile-overlay-title');
  const overlayBody = document.getElementById('feature-mobile-overlay-body');
  const closeBtn = document.getElementById('feature-mobile-overlay-close');

  const openOverlay = (index) => {
    const item = features[index];
    if (!overlay || !overlayIcon || !overlayTitle || !overlayBody || !item) return;
    overlayIcon.setAttribute('src', item.iconSrc);
    overlayTitle.textContent = item.title;
    overlayBody.textContent = item.body;
    overlay.classList.remove('hidden');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const closeOverlay = () => {
    if (!overlay) return;
    overlay.classList.add('hidden');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  document.querySelectorAll('[data-feature-index]').forEach((button) => {
    button.addEventListener('click', () => {
      const index = Number(button.getAttribute('data-feature-index'));
      openOverlay(index);
    });
  });

  closeBtn?.addEventListener('click', closeOverlay);
  overlay?.addEventListener('click', (event) => {
    if (event.target === overlay) closeOverlay();
  });
</script>
