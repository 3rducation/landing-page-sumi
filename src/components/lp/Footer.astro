---
const { footer } = Astro.props;
---

<footer class="bg-[#0F3D2E] py-10">
  <div class="max-w-[1160px] mx-auto px-5 md:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <img src="/images/logo-transparent.png" alt="3rducation" class="h-8 w-auto brightness-0 invert" />
        <span class="text-white/80 text-sm">{footer.company}</span>
      </div>
      <div class="flex gap-5 text-xs text-white/50">
        <a href="#" class="hover:text-white/80 transition-colors">プライバシーポリシー（準備中）</a>
        <a href="#" class="hover:text-white/80 transition-colors">利用規約（準備中）</a>
      </div>
    </div>
    <div class="mt-6 border-t border-white/10 pt-5 text-center text-xs text-white/40">
      {footer.copyright}
    </div>
  </div>
</footer>
